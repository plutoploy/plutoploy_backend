{
  "name": "plutoploy",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx index.ts",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop plutoploy",
    "pm2:restart": "pm2 restart plutoploy",
    "pm2:reload": "pm2 delete plutoploy 2>/dev/null || true && pm2 start ecosystem.config.cjs",
    "pm2:logs": "pm2 logs plutoploy",
    "pm2:delete": "pm2 delete plutoploy"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "better-sqlite3": "^11.0.0",
    "hono": "^4.11.9"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.19.37",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  }
}
